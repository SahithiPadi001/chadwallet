# ─── Privy ───────────────────────────────────────────────
# Get from: https://dashboard.privy.io → your app → Settings
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# ─── Supabase ────────────────────────────────────────────
# Get from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── BirdEye ─────────────────────────────────────────────
# Get from: https://birdeye.so/data-api → sign up → API Keys
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ─── Alchemy (Solana RPC) ────────────────────────────────
# Get from: https://dashboard.alchemy.com → create app → Solana Mainnet
NEXT_PUBLIC_ALCHEMY_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/your_key_here

# ─── Azure OpenAI (AI token insights) ────────────────────
# Get from: https://portal.azure.com → Azure OpenAI resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
